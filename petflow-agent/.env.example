# PetFlow WhatsApp Agent — Environment Variables
# Copy this file to .env and fill in your values

# OpenAI API Key (for Luna's brain)
OPENAI_API_KEY=your_openai_api_key_here

# Evolution API (for WhatsApp messaging)
EVOLUTION_API_URL=https://your-evolution-api-url.com
EVOLUTION_API_KEY=your_evolution_api_key_here

# The Evolution API instance name for this WhatsApp connection
# Must match the instance you created in Evolution API dashboard
INSTANCE_NAME=PetFlow_Spa

# URL where this agent is publicly accessible (used for webhook registration)
# Example: https://your-agent.your-server.com OR use ngrok for local testing
AGENT_PUBLIC_URL=https://your-agent-url.com

# Port for the local server
PORT=3002

# Your pet spa's booking link (cal.com or any booking platform)
BOOKING_LINK=https://cal.com/your-link

# Your spa name (shown in Luna's intro message)
SPA_NAME=PetFlow Spa
